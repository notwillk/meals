---
const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="content-language" content="en">
  <meta name="google" content="notranslate">
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,400;1,400&family=DM+Sans:ital,wght@0,400;0,500;0,600;1,400&family=Libre+Baskerville:wght@400;700&display=swap" rel="stylesheet">
  <style is:global>
    :root {
      --font-body: 'DM Sans', system-ui, -apple-system, sans-serif;
      --font-display: 'Libre Baskerville', Georgia, serif;
      --font-mono: 'DM Mono', ui-monospace, monospace;
      
      --color-text: #2c2825;
      --color-text-muted: #6b6059;
      --color-bg: #faf8f5;
      --color-surface: #ffffff;
      --color-accent: #b85c38;
      --color-border: #e0d9d0;
      --color-print-border: #000000;
      
      --space-xs: 0.25rem;
      --space-sm: 0.5rem;
      --space-md: 1rem;
      --space-lg: 1.5rem;
      --space-xl: 3rem;
    }
    
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    
    body {
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.7;
      color: var(--color-text);
      background: var(--color-bg);
      padding: var(--space-lg);
    }
    
    main {
      max-width: 68ch;
      margin: 0 auto;
      padding-top: 2.5rem;
    }
    
    h1, h2, h3 {
      font-family: var(--font-display);
      font-weight: 400;
      line-height: 1.2;
      color: var(--color-text);
      margin-bottom: var(--space-md);
    }
    
    h1 { font-size: 2.2rem; }
    h2 { font-size: 1.6rem; margin-top: var(--space-xl); }
    h3 { font-size: 1.3rem; margin-top: var(--space-lg); }
    
    h4, .label {
      font-family: var(--font-body);
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--color-text-muted);
      margin-bottom: var(--space-xs);
    }
    
    a:any-link, a:visited, a:link {
      color: var(--color-text) !important;
      text-decoration: none !important;
      transition: opacity 0.15s ease;
    }

    a:hover {
      opacity: 0.7;
      text-decoration: underline !important;
    }
    
    p {
      margin-bottom: var(--space-md);
    }
    
    ul, ol {
      margin-bottom: var(--space-md);
      padding-left: 1.5rem;
    }
    
    li {
      margin-bottom: var(--space-xs);
    }
    
    .mono {
      font-family: var(--font-mono);
      font-size: 0.9em;
    }
    
    .muted {
      color: var(--color-text-muted);
    }
    
    .breadcrumbs {
      position: sticky;
      top: 0;
      z-index: 100;
      padding: var(--space-sm) var(--space-lg);
      padding-bottom: var(--space-md);
      border-bottom: 1px solid var(--color-border);
      background: var(--color-bg);
    }

    .breadcrumbs a,
    .breadcrumbs span {
      font-family: var(--font-mono);
      font-size: 0.85rem;
    }

    /* Current page (last item) - accent color */
    .breadcrumbs span:last-child {
      color: var(--color-accent);
    }

    .breadcrumbs .sep {
      margin: 0 0.4em;
      color: var(--color-text-muted);
      opacity: 0.5;
    }
    
    /* Card component */
    .card {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      padding: var(--space-lg);
      margin-bottom: var(--space-lg);
    }
    
    /* Table base */
    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: var(--space-lg);
      font-size: 0.95rem;
    }
    
    th {
      font-family: var(--font-body);
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--color-text-muted);
      padding: var(--space-sm) var(--space-md);
      border-bottom: 2px solid var(--color-border);
      text-align: left;
    }
    
    td {
      padding: var(--space-sm) var(--space-md);
      border-bottom: 1px solid var(--color-border);
      vertical-align: top;
    }
    
    tr:last-child td {
      border-bottom: none;
    }
    
    /* Warning styles */
    .warning {
      padding: var(--space-md) var(--space-lg);
      margin-bottom: var(--space-lg);
      border-radius: 4px;
      border-left: 3px solid;
    }
    
    .warning-red {
      background: #fff8f8;
      border-color: #d95757;
    }
    
    .warning-yellow {
      background: #fffdf5;
      border-color: #d9b757;
    }
    
    /* Responsive */
    @media (max-width: 600px) {
      body {
        padding: var(--space-md);
      }
      
      h1 { font-size: 1.8rem; }
      h2 { font-size: 1.4rem; }
      
      table {
        font-size: 0.875rem;
      }
      
      th, td {
        padding: var(--space-xs) var(--space-sm);
      }
    }
    
    /* Print styles */
    @media print {
      :root {
        --color-text: #000;
        --color-text-muted: #333;
        --color-bg: #fff;
        --color-surface: #fff;
        --color-accent: #000;
        --color-border: #999;
      }
      
      body {
        background: white;
        color: black;
        max-width: none;
        padding: 0;
        line-height: 1.5;
        font-size: 11pt;
      }
      
      main {
        max-width: none;
        margin: 0;
      }
      
      a:any-link, a:visited, a:link {
        color: black !important;
        text-decoration: none !important;
      }
      
      nav {
        display: none;
      }
      
      h1 { font-size: 18pt; }
      h2 { font-size: 14pt; margin-top: 1.5rem; }
      h3 { font-size: 12pt; margin-top: 1rem; }
      
      .card, .warning {
        border: 1pt solid #000;
        border-radius: 0;
        background: white;
        break-inside: avoid;
        padding: 0.75rem;
        margin-bottom: 0.75rem;
      }
      
      .warning-red, .warning-yellow {
        border-left: 2pt solid #000;
      }
      
      th {
        color: #333;
        border-bottom: 1pt solid #000;
      }
      
      td {
        border-bottom: 0.5pt solid #999;
        padding: 0.4rem;
      }
      
      @page {
        size: letter;
        margin: 0.75in;
      }
      
      @page :first {
        margin-top: 1in;
      }
    }
  </style>
</head>
<body>
  <main>
    <slot />
  </main>
</body>
</html>
