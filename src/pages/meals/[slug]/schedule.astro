---
import Layout from '../../../layouts/Layout.astro';
import { getAllMenus, getMenu } from '../../../data/loader.ts';
import { formatDuration, formatNumeric, getPhaseOffsetStr, getPhaseTimeStr, parseDurationMs } from '../../../utils/time.ts';
import type { Menu, Course, Dish, Component, Preparation, Errand } from '../../../types/index.ts';

interface ScheduledItem {
  type: 'preparation' | 'errand';
  name: string;
  description?: string;
  final?: boolean;
  dish?: string;
  dishSlug?: string;
  component?: string;
  time: string;
  offsetMs: number;
  durationMs: number;
  duration: string;
}

interface UnscheduledItem {
  type: 'preparation' | 'errand';
  name: string;
  description?: string;
  dishSlug?: string;
  component?: string;
  source: string;
  final?: boolean;
  dish?: string;
}

interface DependencyViolation {
  preparation: string;
  dish: string;
  dependency: string;
  issue: string;
}

export function getStaticPaths() {
  const menus = getAllMenus();
  return menus.map((menu: Menu) => ({
    params: { slug: menu.slug }
  }));
}

const { slug } = Astro.params;
const menu = getMenu(slug);

if (!menu) {
  return Astro.redirect('/404');
}

const serviceTime = menu.start_time ? new Date(menu.start_time).getTime() : new Date().getTime();

function formatDateHeader(dateStr: string): string {
  const dt = new Date(dateStr);
  const dayName = dt.toLocaleDateString('en-US', { weekday: 'long' });
  const month = (dt.getMonth() + 1).toString();
  const day = dt.getDate().toString();
  return `${dayName} ${month}/${day}`;
}

function formatMenuDescription(menu: Menu): string {
  const parts: string[] = [];
  if (menu.date) {
    const dt = new Date(menu.date);
    parts.push(dt.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' }));
  }
  if (menu.start_time) {
    const date = new Date(menu.start_time);
    parts.push(date.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }));
  }
  return parts.join(' · ');
}

const scheduledItems: ScheduledItem[] = [];
const unscheduledItems: UnscheduledItem[] = [];
const dependencyViolations: DependencyViolation[] = [];

const preparationLookup: Record<string, Preparation> = {};
menu.courses.forEach((course: Course) => {
  course.dishes.forEach((dish: Dish) => {
    if (dish.components) {
      dish.components.forEach((component: Component) => {
        if (component.preparations) {
          component.preparations.forEach((prep: Preparation) => {
            preparationLookup[`${dish.slug}:${prep.id}`] = prep;
          });
        }
      });
    }
  });
});

menu.courses.forEach((course: Course) => {
  course.dishes.forEach((dish: Dish) => {
    if (dish.components) {
      dish.components.forEach((component: Component) => {
        if (component.preparations) {
          component.preparations.forEach((prep: Preparation) => {
            if (prep.time && prep.duration) {
              const prepMs = new Date(prep.time).getTime();
              const offsetMs = prepMs - serviceTime;
              const durationMs = parseDurationMs(prep.duration);
              
              if (prep.follows) {
                prep.follows.forEach((dep: string) => {
                  const depPrep = preparationLookup[`${dish.slug}:${dep}`];
                  if (depPrep && depPrep.time && depPrep.duration) {
                    const depMs = new Date(depPrep.time).getTime();
                    const depOffsetMs = depMs - serviceTime;
                    const depDurationMs = parseDurationMs(depPrep.duration);
                    const depEndMs = depOffsetMs + depDurationMs;
                    if (offsetMs < depEndMs) {
                      dependencyViolations.push({
                        preparation: prep.id,
                        dish: dish.description,
                        dependency: dep,
                        issue: `${getPhaseOffsetStr(prep.time, serviceTime)} but ${dep} ends at ${getPhaseOffsetStr(new Date(serviceTime + depEndMs).toISOString(), serviceTime)}`
                      });
                    }
                  }
                });
              }
              
              scheduledItems.push({
                type: 'preparation',
                name: prep.id,
                description: prep.description,
                final: prep.final,
                dish: dish.description,
                dishSlug: dish.slug,
                component: component.id,
                time: prep.time,
                offsetMs,
                durationMs,
                duration: prep.duration
              });
            } else {
              unscheduledItems.push({
                type: 'preparation',
                name: prep.id,
                description: prep.description,
                dishSlug: dish.slug,
                component: component.id,
                source: dish.description
              });
            }
          });
        }
      });
    }
  });
});

if (menu.errands) {
  menu.errands.forEach((errand: Errand) => {
    if (errand.time && errand.duration) {
      const errandMs = new Date(errand.time);
      const offsetMs = errandMs.getTime() - serviceTime;
      const durationMs = parseDurationMs(errand.duration);
      scheduledItems.push({
        type: 'errand',
        name: errand.name,
        dish: 'Errands',
        time: errandMs.toISOString(),
        offsetMs,
        durationMs,
        duration: errand.duration
      });
    } else {
      unscheduledItems.push({
        type: 'errand',
        name: errand.name,
        source: 'Errands'
      });
    }
  });
}

const itemsByDate: Record<string, ScheduledItem[]> = {};
scheduledItems.forEach((item: ScheduledItem) => {
  const dt = new Date(item.time);
  const dateKey = dt.toISOString().split('T')[0];
  if (!itemsByDate[dateKey]) itemsByDate[dateKey] = [];
  itemsByDate[dateKey].push(item);
});

Object.keys(itemsByDate).forEach((date: string) => {
  itemsByDate[date].sort((a: ScheduledItem, b: ScheduledItem) => a.offsetMs - b.offsetMs);
});

const sortedDates: string[] = Object.keys(itemsByDate).sort();
---

<Layout title={`${menu.name} - Schedule`} description={formatMenuDescription(menu)}>
  <nav class="breadcrumbs">
    <a href="/">Menus</a><span class="sep">/</span><a href={`/meals/${slug}`}>{menu.name}</a><span class="sep">/</span><span>Schedule</span>
  </nav>
  
  <h1>Schedule</h1>
  <p class="subtitle muted mono">{menu.name}</p>
  
  {dependencyViolations.length > 0 && (
    <div class="warning warning-red">
      <h3>Dependency Violations</h3>
      <ul>
        {dependencyViolations.map(v => (
          <li><strong>{v.preparation}</strong> ({v.dish}): {v.issue}</li>
        ))}
      </ul>
    </div>
  )}
  
  {unscheduledItems.length > 0 && (
    <div class="warning warning-yellow">
      <h3>Unscheduled Items</h3>
      <ul>
        {unscheduledItems.map(item => (
          <li>
            {item.type === 'preparation' ? (
              <a href={`/recipes/${slug}/${item.dishSlug}#${item.name}`}>{item.final ? `Serve: ${item.dish}` : (item.description || item.name)}</a>
            ) : (
              <strong>{item.name}</strong>
            )}
          </li>
        ))}
      </ul>
    </div>
  )}
  
  {sortedDates.map(date => (
    <section class="day-section">
      <h2>{formatDateHeader(date)}</h2>
      <table>
        <thead>
          <tr>
            <th>Offset</th>
            <th>Time</th>
            <th>Task</th>
          </tr>
        </thead>
        <tbody>
          {itemsByDate[date].map(item => (
            <tr>
              <td class="mono">{getPhaseOffsetStr(item.time, serviceTime)}</td>
              <td class="mono muted">{getPhaseTimeStr(item.time)}</td>
              <td>
                {item.type === 'preparation' ? (
                  <a href={`/recipes/${slug}/${item.dishSlug}#${item.name}`}>
                    {item.final ? `Serve: ${item.dish}` : (item.description || item.name)}
                  </a>
                ) : (
                  <span>{item.name}</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  ))}
  
  <style>
    h1 {
      margin-top: var(--space-md);
    }

    .subtitle {
      margin-top: calc(var(--space-xs) * -1);
      margin-bottom: var(--space-xl);
      font-size: 0.9rem;
    }
    
    .day-section {
      margin-bottom: var(--space-xl);
      border: 1px solid var(--color-border);
      border-radius: 6px;
      overflow: hidden;
    }

    .day-section h2 {
      margin: 0;
      padding: 0.6em 1em;
      font-size: 1rem;
      font-family: var(--font-body);
      font-weight: 600;
      background: var(--color-surface);
      border-bottom: 1px solid var(--color-border);
    }

    table {
      font-size: 0.95rem;
      margin: 0;
      background: white;
      width: 100%;
    }

    tbody tr:first-child td {
      padding-top: 0.7em;
    }

    tbody tr:last-child td {
      padding-bottom: 0.7em;
    }

    td {
      padding-left: 1em;
      padding-right: 1em;
    }

    th {
      text-align: left;
      padding-left: 1em;
      padding-right: 1em;
    }

    th:first-child {
      width: 6rem;
    }

    th:nth-child(2) {
      width: 5rem;
    }

    @media (max-width: 600px) {
      th:first-child, th:nth-child(2) {
        width: auto;
      }
    }

    @media print {
      .breadcrumbs {
        display: none;
      }

      .day-section {
        border-color: black;
      }

      .day-section h2 {
        font-size: 11pt;
        background: none;
      }

      table {
        font-size: 10pt;
      }
    }
  </style>
</Layout>
