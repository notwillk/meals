---
import Layout from '../../../layouts/Layout.astro';
import { getAllMeals, getMeal } from '../../../data/loader.ts';
import { formatDuration, formatNumeric, getPhaseOffsetStr, getPhaseTimeStr, parseDurationMs } from '../../../utils/time.ts';

export function getStaticPaths() {
  const meals = getAllMeals();
  return meals.map(meal => ({
    params: { slug: meal.slug }
  }));
}

const { slug } = Astro.params;
const meal = getMeal(slug);

if (!meal) {
  return Astro.redirect('/404');
}

const serviceTime = meal.start_time ? new Date(meal.start_time).getTime() : new Date().getTime();

function minutesToTime(minutes: number): string {
  const h = Math.floor(minutes / 60);
  const m = minutes % 60;
  return `${h.toString().padStart(2, '0')}:${m.toString().padStart(2, '0')}`;
}

function formatDateHeader(dateStr: string): string {
  const dt = new Date(dateStr);
  const dayName = dt.toLocaleDateString('en-US', { weekday: 'long' });
  const month = (dt.getMonth() + 1).toString();
  const day = dt.getDate().toString();
  return `${dayName} ${month}/${day}`;
}

// Collect all phases and errands with time/duration
const scheduledItems = [];
const unscheduledItems = [];
const dependencyViolations = [];

// Build phase lookup
const phaseLookup = {};
meal.courses.forEach(course => {
  course.recipes.forEach(recipe => {
    if (recipe.phases) {
      recipe.phases.forEach(phase => {
        phaseLookup[`${recipe.slug}:${phase.id}`] = phase;
      });
    }
  });
});

// Check phases
meal.courses.forEach(course => {
  course.recipes.forEach(recipe => {
    if (recipe.phases) {
      recipe.phases.forEach(phase => {
        if (phase.time && phase.duration) {
          const phaseMs = new Date(phase.time).getTime();
          const offsetMs = phaseMs - serviceTime;
          const durationMs = parseDurationMs(phase.duration);
          
          // Check dependency violations
          if (phase.follows) {
            phase.follows.forEach(dep => {
              const depPhase = phaseLookup[`${recipe.slug}:${dep}`];
              if (depPhase && depPhase.time && depPhase.duration) {
                const depMs = new Date(depPhase.time).getTime();
                const depOffsetMs = depMs - serviceTime;
                const depDurationMs = parseDurationMs(depPhase.duration);
                const depEndMs = depOffsetMs + depDurationMs;
                if (offsetMs < depEndMs) {
                  dependencyViolations.push({
                    phase: phase.id,
                    recipe: recipe.description,
                    dependency: dep,
                    issue: `${getPhaseOffsetStr(phase.time, serviceTime)} but ${dep} ends at ${getPhaseOffsetStr(new Date(serviceTime + depEndMs).toISOString(), serviceTime)}`
                  });
                }
              }
            });
          }
          
          scheduledItems.push({
            type: 'phase',
            name: phase.id,
            description: phase.description,
            final: phase.final,
            recipe: recipe.description,
            recipeSlug: recipe.slug,
            time: phase.time,
            offsetMs,
            durationMs,
            duration: phase.duration
          });
        } else {
          unscheduledItems.push({
            type: 'phase',
            name: phase.id,
            description: phase.description,
            recipeSlug: recipe.slug,
            source: recipe.description
          });
        }
      });
    }
  });
});

// Check errands
if (meal.errands) {
  meal.errands.forEach(errand => {
    if (errand.time && errand.duration) {
      const errandMs = new Date(errand.time);
      const offsetMs = errandMs.getTime() - serviceTime;
      const durationMs = parseDurationMs(errand.duration);
      scheduledItems.push({
        type: 'errand',
        name: errand.name,
        recipe: 'Errands',
        time: errandMs.toISOString(),
        offsetMs,
        durationMs,
        duration: errand.duration
      });
    } else {
      unscheduledItems.push({
        type: 'errand',
        name: errand.name,
        source: 'Errands'
      });
    }
  });
}

// Group items by date
const itemsByDate = {};
scheduledItems.forEach(item => {
  const dt = new Date(item.time);
  const dateKey = dt.toISOString().split('T')[0];
  if (!itemsByDate[dateKey]) itemsByDate[dateKey] = [];
  itemsByDate[dateKey].push(item);
});

// Sort items within each date
Object.keys(itemsByDate).forEach(date => {
  itemsByDate[date].sort((a, b) => a.offsetMs - b.offsetMs);
});

const sortedDates = Object.keys(itemsByDate).sort();

// For Gantt chart - find time range
const allItems = scheduledItems;
const minOffset = allItems.length > 0 ? Math.min(...allItems.map(i => i.offsetMs)) : 0;
const maxOffset = allItems.length > 0 ? Math.max(...allItems.map(i => i.offsetMs + i.durationMs)) : 0;
const totalRange = maxOffset - minOffset;

function getGanttMarkers() {
  const numMarkers = 10;
  const markers = [];
  for (let i = 0; i <= numMarkers; i++) {
    const offset = minOffset + (totalRange / numMarkers) * i;
    const dt = new Date(serviceTime + offset);
    let hours = dt.getHours();
    const minutes = dt.getMinutes().toString().padStart(2, '0');
    const ampm = hours >= 12 ? 'pm' : 'am';
    hours = hours % 12 || 12;
    markers.push(`${hours}:${minutes}${ampm}`);
  }
  return markers;
}
---

<Layout title={`${meal.name} - Schedule`}>
  <nav class="breadcrumbs">
    <a href="/">Meals</a> / <a href={`/meals/${slug}`}>{meal.name}</a> / <span>Schedule</span>
  </nav>
  <h1>{meal.name} - Schedule</h1>
  
  {dependencyViolations.length > 0 && (
    <div class="warning warning-red">
      <h3>Dependency Violations</h3>
      <ul>
        {dependencyViolations.map(v => (
          <li><strong>{v.phase}</strong> ({v.recipe}): {v.issue}</li>
        ))}
      </ul>
    </div>
  )}
  
  {unscheduledItems.length > 0 && (
    <div class="warning warning-yellow">
      <h3>Unscheduled Items</h3>
      <ul>
        {unscheduledItems.map(item => (
          <li>
            {item.type === 'phase' ? (
              <a href={`/recipes/${slug}/${item.recipeSlug}#${item.name}`}>{item.final ? `Serve: ${item.recipe}` : (item.description || item.name)}</a>
            ) : (
              <strong>{item.name}</strong>
            )}
          </li>
        ))}
      </ul>
    </div>
  )}
  
  {/* Gantt chart temporarily disabled
  {allItems.length > 0 && (
    <div class="gantt-container">
      <div class="gantt-header">
        <div class="gantt-label-header"></div>
        {getGanttMarkers().map(t => (
          <div class="gantt-hour" style="flex: 1;">{t}</div>
        ))}
      </div>
      
      <div class="gantt-body">
        {allItems.map(item => {
          const leftPercent = ((item.offsetMs - minOffset) / totalRange) * 100;
          const widthPercent = (item.durationMs / totalRange) * 100;
          
          return (
            <div class="gantt-row">
              <div class="gantt-label">
                <span class="item-name">{item.name}</span>
                <span class="item-recipe">{item.recipe}</span>
              </div>
              <div class="gantt-bar-container">
                <div 
                  class={`gantt-bar ${item.type === 'errand' ? 'errand' : 'phase'}`}
                  style={`left: ${leftPercent}%; width: ${Math.max(widthPercent, 1)}%;`}
                  title={`${item.name} - ${getPhaseOffsetStr(item.time, serviceTime)} - ${formatDuration(item.duration)}`}
                >
                  <span class="bar-label">{formatDuration(item.duration)}</span>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  )}
  */}
  
  {sortedDates.map(date => (
    <div class="schedule-section">
      <h2>{formatDateHeader(date)}</h2>
      <table>
        <thead>
          <tr>
            <th>T-Offset</th>
            <th>Time</th>
            <th>Name</th>
          </tr>
        </thead>
          <tbody>
          {itemsByDate[date].map(item => (
            <tr>
              <td class="time-cell">{getPhaseOffsetStr(item.time, serviceTime)}</td>
              <td class="time-cell">{getPhaseTimeStr(item.time)}</td>
              <td>
                {item.type === 'phase' ? (
                  <a href={`/recipes/${slug}/${item.recipeSlug}#${item.name}`}>{item.final ? `Serve: ${item.recipe}` : (item.description || item.name)}</a>
                ) : (
                  <strong>{item.name}</strong>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  ))}
</Layout>

<style>
  .schedule-section {
    margin-bottom: 2rem;
  }

  .time-cell {
    font-family: monospace;
    font-size: 0.875rem;
  }

  .gantt-container {
    border: 1px solid #ddd;
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 2rem;
  }
  
  .gantt-header {
    display: flex;
    background: #f5f5f5;
    border-bottom: 1px solid #ddd;
  }
  
  .gantt-label-header {
    width: 150px;
    min-width: 150px;
    padding: 0.5rem;
    font-weight: 600;
    border-right: 1px solid #ddd;
  }
  
  .gantt-hour {
    padding: 0.5rem;
    text-align: center;
    font-size: 0.75rem;
    color: #666;
    border-right: 1px solid #eee;
  }
  
  .gantt-row {
    display: flex;
    border-bottom: 1px solid #eee;
  }
  
  .gantt-row:last-child {
    border-bottom: none;
  }
  
  .gantt-label {
    width: 150px;
    min-width: 150px;
    padding: 0.5rem;
    border-right: 1px solid #ddd;
    display: flex;
    flex-direction: column;
    background: #fafafa;
  }
  
  .item-name {
    font-weight: 500;
    font-size: 0.875rem;
  }
  
  .item-recipe {
    font-size: 0.75rem;
    color: #666;
  }
  
  .gantt-bar-container {
    flex: 1;
    position: relative;
    padding: 0.5rem 0;
    background: repeating-linear-gradient(
      90deg,
      transparent,
      transparent 19%,
      #f0f0f0 19%,
      #f0f0f0 20%
    );
  }
  
  .gantt-bar {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    height: 24px;
    border-radius: 3px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    color: white;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    cursor: pointer;
  }
  
  .gantt-bar.phase {
    background: #4a90d9;
  }
  
  .gantt-bar.errand {
    background: #d98c4a;
  }
  
  .gantt-bar:hover {
    opacity: 0.9;
  }

  .breadcrumbs {
    margin-bottom: 1rem;
    font-size: 0.875rem;
    color: #666;
  }
  .breadcrumbs a {
    color: #0066cc;
  }
  .breadcrumbs span {
    color: #333;
  }
  
  table {
    width: 100%;
    border-collapse: collapse;
  }
  
  th, td {
    text-align: left;
    padding: 0.5rem;
    border-bottom: 1px solid #eee;
  }
  
  th {
    font-weight: 600;
    color: #666;
    font-size: 0.875rem;
    text-align: left;
    padding-left: 0.5rem;
  }
</style>