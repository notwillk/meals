---
import Layout from '../../../layouts/Layout.astro';
import { getAllMenus, getMenu } from '../../../data/loader.ts';
import type { Menu, Course, Dish } from '../../../types/index.ts';

export function getStaticPaths() {
  const menus = getAllMenus();
  return menus.map((menu: Menu) => ({
    params: { slug: menu.slug }
  }));
}

const { slug } = Astro.params;
const menu = getMenu(slug);

if (!menu) {
  return Astro.redirect('/404');
}

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' });
}

function formatTime(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
}

function formatMenuDescription(menu: Menu): string {
  const parts: string[] = [];
  if (menu.date) {
    parts.push(formatDate(menu.date));
  }
  if (menu.start_time) {
    parts.push(formatTime(menu.start_time));
  }
  return parts.join(' · ');
}

function parseDurationMins(durationStr: string | undefined): number {
  if (!durationStr) return 0;
  const match = durationStr.match(/^PT(?:(\d+)H)?(?:(\d+)M)?/);
  if (!match) return 0;
  const hours = parseInt(match[1] || '0');
  const minutes = parseInt(match[2] || '0');
  return hours * 60 + minutes;
}

function formatServiceOffset(minutes: number): string {
  if (minutes === 0) return 'T=0';
  const prefix = minutes > 0 ? 'T+' : 'T-';
  const absMins = Math.abs(minutes);
  const num = parseFloat(absMins.toFixed(1));
  return `${prefix}${num}m`;
}

const visibleCourses: Course[] = menu.courses.filter((c: Course) => !c.hidden);

const firstCourseIndex: number = visibleCourses.findIndex((c: Course) => c.first_course);

let offsetFromFirst = 0;
const coursesWithOffset = visibleCourses.map((course: Course, idx: number) => {
  let serviceOffset: number;
  if (idx < firstCourseIndex) {
    let preOffset = 0;
    for (let i = idx; i < firstCourseIndex; i++) {
      preOffset -= parseDurationMins(visibleCourses[i].duration);
    }
    serviceOffset = preOffset;
  } else if (idx === firstCourseIndex) {
    serviceOffset = 0;
  } else {
    offsetFromFirst += parseDurationMins(visibleCourses[idx - 1].duration);
    serviceOffset = offsetFromFirst;
  }
  return { ...course, serviceOffset };
});
---

<Layout title={menu.name} description={formatMenuDescription(menu)}>
  <nav class="breadcrumbs">
    <a href="/">Menus</a><span class="sep">/</span><span>{menu.name}</span>
  </nav>
  
  <header class="menu-header">
    <h1>{menu.name}</h1>
    <div class="menu-meta">
      {menu.date && <span class="mono">{formatDate(menu.date)}</span>}
      {menu.start_time && (
        <span class="muted"> &middot; Service at {formatTime(menu.start_time)}</span>
      )}
    </div>
  </header>
  
  <nav class="page-links">
    <a href={`/meals/${slug}/schedule`}>Schedule</a>
    <span class="dot muted">&middot;</span>
    <a href={`/meals/${slug}/shopping-list`}>Shopping List</a>
  </nav>

  <section class="courses">
    <ul class="course-list">
      {coursesWithOffset.map(course => (
        <li class="course-item">
          <div class="course-header">
            <span class="offset mono">{formatServiceOffset(course.serviceOffset)}</span>
            <span class="course-name">{course.name}</span>
            {course.description && (
              <span class="course-desc muted">{course.description}</span>
            )}
          </div>
          <ul class="course-dish-list">
            {course.dishes.map((dish: Dish) => (
              <li>
                <a href={`/recipes/${slug}/${dish.slug}`}>{dish.description}</a>
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ul>
  </section>
  
  <style>
    .breadcrumbs {
      margin-bottom: var(--space-lg);
    }

    .menu-header {
      margin-top: var(--space-md);
      margin-bottom: var(--space-xl);
    }
    
    .menu-header h1 {
      margin-bottom: var(--space-sm);
    }
    
    .menu-meta {
      font-size: 0.95rem;
    }
    
    .page-links {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 0.4em;
      margin-top: var(--space-xs);
      margin-bottom: var(--space-md);
      font-size: 0.95rem;
    }

    .course-list {
      list-style: none;
      padding: 0;
    }
    
    .course-item {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 4px;
      padding: var(--space-lg);
      margin-bottom: var(--space-md);
    }
    
    .course-header {
      display: flex;
      align-items: baseline;
      gap: var(--space-md);
      width: 100%;
    }

    .offset {
      color: var(--color-accent);
      font-weight: 500;
      min-width: 3rem;
    }

    .course-name {
      font-weight: 500;
      font-size: 1.1rem;
    }

    .course-desc {
      font-size: 0.9rem;
      font-style: italic;
      margin-left: auto;
    }

    .course-dish-list {
      list-style: none;
      padding: 0;
      margin: var(--space-md) 0 0;
      font-size: 0.95rem;
      text-align: center;
    }

    .course-dish-list li {
      margin: 0.3em 0;
    }

    @media (max-width: 600px) {
      .course-header {
        flex-direction: column;
        gap: var(--space-xs);
      }

      .offset {
        min-width: auto;
      }
    }

    @media print {
      .breadcrumbs,
      .page-links {
        display: none;
      }

      .course-item {
        background: white;
        border: 0.5pt solid #999;
        border-radius: 0;
        padding: 0.5rem;
        margin-bottom: 0.5rem;
        break-inside: avoid;
      }

      .course-header {
        flex-direction: row;
        gap: 0.5rem;
      }

      .offset {
        color: black;
      }
    }
  </style>
</Layout>
