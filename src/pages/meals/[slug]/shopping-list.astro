---
import Layout from '../../../layouts/Layout.astro';
import { getAllMeals, getMeal } from '../../../data/loader.ts';

function parseQty(qty) {
  if (typeof qty === 'number') return qty;
  if (typeof qty === 'string') {
    if (qty.includes('/')) {
      const parts = qty.split(' ');
      let total = 0;
      for (const part of parts) {
        if (part.includes('/')) {
          const [num, den] = part.split('/');
          total += parseFloat(num) / parseFloat(den);
        } else {
          total += parseFloat(part);
        }
      }
      return total;
    }
    return parseFloat(qty) || 0;
  }
  return 0;
}

function collectIngredientsBySource(meal) {
  const sourceGroups = new Map();

  for (const course of meal.courses) {
    if (course.hidden) continue;
    
    for (const recipe of course.recipes) {
      if (!recipe.phases) continue;

      for (const phase of recipe.phases) {
        const phaseIngredients = phase.ingredients || [];
        for (const ing of phaseIngredients) {
          addIngredientBySource(sourceGroups, ing, recipe.description);
        }

        const stepIngredients = phase.steps || [];
        for (const step of stepIngredients) {
          const stepIngs = step.ingredients || [];
          for (const ing of stepIngs) {
            addIngredientBySource(sourceGroups, ing, recipe.description);
          }
        }
      }
    }
  }

  const result = new Map();
  
  for (const [source, ingredientMap] of sourceGroups) {
    const items = Array.from(ingredientMap.values())
      .filter(item => !item.homemade)
      .sort((a, b) => a.name.toLowerCase().localeCompare(b.name.toLowerCase()));
    
    if (items.length > 0) {
      result.set(source, items);
    }
  }

  return result;
}

function addIngredientBySource(sourceGroups, ing, recipeName) {
  const source = (ing.source && ing.source.trim()) ? ing.source.trim() : 'Grocery Store';
  const key = ing.name.toLowerCase();
  const ingUnit = ing.unit || '';
  const ingQty = parseQty(ing.qty);
  
  if (!sourceGroups.has(source)) {
    sourceGroups.set(source, new Map());
  }
  const map = sourceGroups.get(source);
  
  if (!map.has(key)) {
    map.set(key, {
      name: ing.name,
      qty: ingQty,
      unitQuantities: ingUnit ? [[ingQty, ingUnit]] : [],
      note: ing.note || '',
      preparation: ing.preparation || '',
      homemade: ing.homemade || false,
      recipes: [recipeName]
    });
  } else {
    const existing = map.get(key);
    existing.qty += ingQty;
    
    if (!ingUnit) {
      if (ing.note && !existing.note.includes(ing.note)) {
        existing.note = existing.note ? `${existing.note}; ${ing.note}` : ing.note;
      }
      if (ing.preparation && !existing.preparation.includes(ing.preparation)) {
        existing.preparation = existing.preparation ? `${existing.preparation}; ${ing.preparation}` : ing.preparation;
      }
      if (ing.homemade) {
        existing.homemade = true;
      }
      if (!existing.recipes.includes(recipeName)) {
        existing.recipes.push(recipeName);
      }
      return;
    }
    
    const lastUnitEntry = existing.unitQuantities.length > 0 ? existing.unitQuantities[existing.unitQuantities.length - 1] : null;
    
    if (lastUnitEntry && lastUnitEntry[1].toLowerCase() === ingUnit.toLowerCase()) {
      lastUnitEntry[0] += ingQty;
    } else {
      existing.unitQuantities.push([ingQty, ingUnit]);
    }
    
    if (ing.note && !existing.note.includes(ing.note)) {
      existing.note = existing.note ? `${existing.note}; ${ing.note}` : ing.note;
    }
    if (ing.preparation && !existing.preparation.includes(ing.preparation)) {
      existing.preparation = existing.preparation ? `${existing.preparation}; ${ing.preparation}` : ing.preparation;
    }
    if (ing.homemade) {
      existing.homemade = true;
    }
    if (!existing.recipes.includes(recipeName)) {
      existing.recipes.push(recipeName);
    }
  }
}

export function getStaticPaths() {
  const meals = getAllMeals();
  return meals.map(meal => ({
    params: { slug: meal.slug }
  }));
}

const { slug } = Astro.params;
const meal = getMeal(slug);

if (!meal) {
  return Astro.redirect('/404');
}

const shoppingListBySource = collectIngredientsBySource(meal);
---

<Layout title={`${meal.name} - Shopping List`}>
  <nav class="breadcrumbs">
    <a href="/">Meals</a> / <a href={`/meals/${slug}`}>{meal.name}</a> / <span>Shopping List</span>
  </nav>
  <h1>{meal.name} - Shopping List</h1>
  
  {shoppingListBySource.size === 0 ? (
    <p>No ingredients found.</p>
  ) : (
    <div class="source-groups">
      {Array.from(shoppingListBySource.entries()).map(([source, items]) => (
        <div class="source-group">
          <h2>{source}</h2>
          <table>
            <thead>
              <tr>
                <th>Ingredient</th>
                <th>Quantity</th>
                <th>Notes</th>
              </tr>
            </thead>
            <tbody>
              {items.map(item => (
                <tr>
                  <td>
                    {item.name}
                    {item.preparation && <span class="prep"> ({item.preparation})</span>}
                  </td>
                  <td>
                    {item.unitQuantities && item.unitQuantities.length > 0 
                      ? item.unitQuantities.filter(uq => uq[0] > 0).map(uq => `${uq[0]} ${uq[1]}`).join(' + ')
                      : (item.qty > 0 ? item.qty : '')}
                  </td>
                  <td>{item.note}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ))}
    </div>
  )}
</Layout>

<style>
  .prep {
    font-style: italic;
    color: #666;
  }
  .homemade {
    color: #0066cc;
    font-weight: 500;
  }
  .breadcrumbs {
    margin-bottom: 1rem;
    font-size: 0.875rem;
    color: #666;
  }
  .breadcrumbs a {
    color: #0066cc;
  }
  .breadcrumbs span {
    color: #333;
  }
  .source-group {
    margin-bottom: 2rem;
  }
  .source-group h2 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
    color: #333;
  }
  table {
    width: 100%;
    border-collapse: collapse;
  }
  th, td {
    text-align: left;
    padding: 0.5rem;
    border-bottom: 1px solid #eee;
  }
  th {
    font-weight: 600;
    color: #666;
    font-size: 0.875rem;
    text-align: left;
    padding-left: 0.5rem;
  }
</style>