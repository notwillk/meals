---
import Layout from '../../../layouts/Layout.astro';
import { getAllMenus, getMenu } from '../../../data/loader.ts';
import type { Menu, Course, Dish, Component, Preparation, Ingredient, Step } from '../../../types/index.ts';

interface IngredientItem {
  name: string;
  qty: number;
  unitQuantities: [number, string][];
  note: string;
  preparation: string;
  homemade: boolean;
  dishes: string[];
}

function parseQty(qty: string | number | undefined): number {
  if (typeof qty === 'number') return qty;
  if (typeof qty === 'string') {
    if (qty.includes('/')) {
      const parts = qty.split(' ');
      let total = 0;
      for (const part of parts) {
        if (part.includes('/')) {
          const [num, den] = part.split('/');
          total += parseFloat(num) / parseFloat(den);
        } else {
          total += parseFloat(part);
        }
      }
      return total;
    }
    return parseFloat(qty) || 0;
  }
  return 0;
}

function collectIngredientsBySource(menu: Menu): Map<string, IngredientItem[]> {
  const sourceGroups = new Map<string, Map<string, IngredientItem>>();

  for (const course of menu.courses) {
    if (course.hidden) continue;
    
    for (const dish of course.dishes) {
      if (!dish.components) continue;

      for (const component of dish.components) {
        if (!component.preparations) continue;
        
        for (const preparation of component.preparations) {
          const prepIngredients = preparation.ingredients || [];
          for (const ing of prepIngredients) {
            addIngredientBySource(sourceGroups, ing, dish.description);
          }

          const stepIngredients = preparation.steps || [];
          for (const step of stepIngredients) {
            const stepIngs = step.ingredients || [];
            for (const ing of stepIngs) {
              addIngredientBySource(sourceGroups, ing, dish.description);
            }
          }
        }
      }
    }
  }

  const result = new Map<string, IngredientItem[]>();
  
  for (const [source, ingredientMap] of sourceGroups) {
    const items = Array.from(ingredientMap.values())
      .filter(item => !item.homemade)
      .sort((a, b) => a.name.toLowerCase().localeCompare(b.name.toLowerCase()));
    
    if (items.length > 0) {
      result.set(source, items);
    }
  }

  return result;
}

function addIngredientBySource(
  sourceGroups: Map<string, Map<string, IngredientItem>>,
  ing: Ingredient,
  dishName: string
): void {
  const source = (ing.source && ing.source.trim()) ? ing.source.trim() : 'Grocery Store';
  const key = ing.name.toLowerCase();
  const ingUnit = ing.unit || '';
  const ingQty = parseQty(ing.qty);
  
  if (!sourceGroups.has(source)) {
    sourceGroups.set(source, new Map());
  }
  const map = sourceGroups.get(source)!;
  
  if (!map.has(key)) {
    map.set(key, {
      name: ing.name,
      qty: ingQty,
      unitQuantities: ingUnit ? [[ingQty, ingUnit]] : [],
      note: ing.note || '',
      preparation: ing.preparation || '',
      homemade: ing.homemade || false,
      dishes: [dishName]
    });
  } else {
    const existing = map.get(key)!;
    existing.qty += ingQty;
    
    if (!ingUnit) {
      if (ing.note && !existing.note.includes(ing.note)) {
        existing.note = existing.note ? `${existing.note}; ${ing.note}` : ing.note;
      }
      if (ing.preparation && !existing.preparation.includes(ing.preparation)) {
        existing.preparation = existing.preparation ? `${existing.preparation}; ${ing.preparation}` : ing.preparation;
      }
      if (ing.homemade) {
        existing.homemade = true;
      }
      if (!existing.dishes.includes(dishName)) {
        existing.dishes.push(dishName);
      }
      return;
    }
    
    const lastUnitEntry = existing.unitQuantities.length > 0 ? existing.unitQuantities[existing.unitQuantities.length - 1] : null;
    
    if (lastUnitEntry && lastUnitEntry[1].toLowerCase() === ingUnit.toLowerCase()) {
      lastUnitEntry[0] += ingQty;
    } else {
      existing.unitQuantities.push([ingQty, ingUnit]);
    }
    
    if (ing.note && !existing.note.includes(ing.note)) {
      existing.note = existing.note ? `${existing.note}; ${ing.note}` : ing.note;
    }
    if (ing.preparation && !existing.preparation.includes(ing.preparation)) {
      existing.preparation = existing.preparation ? `${existing.preparation}; ${ing.preparation}` : ing.preparation;
    }
    if (ing.homemade) {
      existing.homemade = true;
    }
    if (!existing.dishes.includes(dishName)) {
      existing.dishes.push(dishName);
    }
  }
}

export function getStaticPaths() {
  const menus = getAllMenus();
  return menus.map((menu: Menu) => ({
    params: { slug: menu.slug }
  }));
}

const { slug } = Astro.params;
const menu = getMenu(slug);

if (!menu) {
  return Astro.redirect('/404');
}

const shoppingListBySource = collectIngredientsBySource(menu);

function formatMenuDescription(menu: Menu): string {
  const parts: string[] = [];
  if (menu.date) {
    const dt = new Date(menu.date);
    parts.push(dt.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' }));
  }
  if (menu.start_time) {
    const date = new Date(menu.start_time);
    parts.push(date.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }));
  }
  return parts.join(' · ');
}
---

<Layout title={`${menu.name} - Shopping List`} description={formatMenuDescription(menu)}>
  <nav class="breadcrumbs">
    <a href="/">Menus</a><span class="sep">/</span><a href={`/meals/${slug}`}>{menu.name}</a><span class="sep">/</span><span>Shopping List</span>
  </nav>
  
  <h1>Shopping List</h1>
  <p class="subtitle muted">{menu.name}</p>
  
  {shoppingListBySource.size === 0 ? (
    <p>No ingredients found.</p>
  ) : (
    <div class="source-list">
      {Array.from(shoppingListBySource.entries()).map(([source, items]) => (
        <section class="source-section">
          <h3>{source}</h3>
          <ul class="item-list">
            {items.map(item => (
              <li class="item">
                <span class="check-box"></span>
                <span class="item-text"><span class="item-name">{item.name}</span>{item.preparation && <span class="prep"> ({item.preparation})</span>}<span class="comma-sep">, </span><span class="item-qty mono">
                  {item.unitQuantities && item.unitQuantities.length > 0 
                    ? item.unitQuantities.filter(uq => uq[0] > 0).map(uq => `${uq[0]} ${uq[1]}`).join(' + ')
                    : (item.qty > 0 ? item.qty : '')}
                </span>
                {item.note && <span class="item-note"> ({item.note})</span>}
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  )}
  
  <style>
    .subtitle {
      margin-top: calc(var(--space-xs) * -1);
      margin-bottom: var(--space-xl);
    }
    
    h1 {
      margin-top: var(--space-md);
    }

    .source-list {
      margin-top: var(--space-lg);
    }
    
    .source-section {
      margin-bottom: var(--space-xl);
    }
    
    .source-section h3 {
      margin-top: 0;
      margin-bottom: var(--space-sm);
      font-size: 1.1rem;
      font-family: var(--font-body);
      font-weight: 600;
      color: var(--color-accent);
    }
    
    .item-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .item {
      display: flex;
      align-items: center;
      padding: 0.3em 0;
      border-bottom: 1px solid #eee;
    }

    .check-box {
      flex-shrink: 0;
      width: 0.85em;
      height: 0.85em;
      border: 1.5px solid black;
      margin-right: 0.5em;
      vertical-align: middle;
      align-self: center;
    }

    .item-text {
      display: inline;
      vertical-align: middle;
    }

    .item-name {
      font-weight: 600;
    }

    .comma-sep {
      color: var(--color-muted);
    }

    .item-qty {
      color: var(--color-muted);
    }

    .prep,
    .item-note {
      font-size: 0.9em;
      color: var(--color-muted);
    }

    @media print {
      .breadcrumbs,
      .subtitle {
        display: none;
      }

      h1 {
        font-size: 18pt;
      }

      .source-section h3 {
        font-size: 12pt;
        color: black;
      }

      .item {
        font-size: 10pt;
      }
    }
  </style>
</Layout>
