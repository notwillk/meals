---
import Layout from '../layouts/Layout.astro';
import { getAllMeals } from '../data/loader.ts';

const meals = getAllMeals().sort((a, b) => new Date(b.start_time) - new Date(a.start_time));

function formatDate(dateStr) {
  const [year, month, day] = dateStr.split('-');
  return `${month}/${day}/${year}`;
}
---

<Layout title="Meals">
  <h1>Meals</h1>
  
  {meals.length === 0 ? (
    <p>No meals found.</p>
  ) : (
    <ul>
      {meals.map(meal => (
        <li>
          {meal.date && <span>{formatDate(meal.date)} - </span>}
          <a href={`/meals/${meal.slug}`}>{meal.name}</a>
        </li>
      ))}
    </ul>
  )}
</Layout>