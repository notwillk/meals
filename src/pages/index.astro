---
import Layout from '../layouts/Layout.astro';
import { getAllMenus } from '../data/loader.ts';
import type { Menu } from '../types/index.ts';

const menus: Menu[] = getAllMenus().sort((a, b) => new Date(b.start_time ?? 0).getTime() - new Date(a.start_time ?? 0).getTime());

function formatDate(dateStr: string): string {
  const [year, month, day] = dateStr.split('-');
  return `${month}/${day}/${year}`;
}
---

<Layout title="Menus">
  <h1>Menus</h1>
  
  {menus.length === 0 ? (
    <p>No menus found.</p>
  ) : (
    <ul class="menu-list">
      {menus.map(menu => (
        <li class="menu-item">
          <a href={`/meals/${menu.slug}`}>
            <span class="menu-date mono">{menu.date && formatDate(menu.date)}</span>
            <span class="menu-name">{menu.name}</span>
          </a>
        </li>
      ))}
    </ul>
  )}
  
  <style>
    .menu-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    
    .menu-item {
      margin-bottom: var(--space-md);
      padding: var(--space-md) var(--space-lg);
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 4px;
      transition: border-color 0.15s ease;
    }
    
    .menu-item:hover {
      border-color: var(--color-accent);
    }
    
    .menu-item a {
      display: flex;
      align-items: baseline;
      gap: var(--space-md);
      color: var(--color-text);
      text-decoration: none;
    }
    
    .menu-item a:hover {
      text-decoration: none;
      opacity: 1;
    }
    
    .menu-date {
      color: var(--color-text-muted);
      font-size: 0.9rem;
      min-width: 5.5rem;
      flex-shrink: 0;
    }
    
    .menu-name {
      font-size: 1.1rem;
      font-weight: 500;
    }
    
    @media (max-width: 600px) {
      .menu-item a {
        flex-direction: column;
        gap: var(--space-xs);
      }
    }
    
    @media print {
      .menu-item {
        background: white;
        border: none;
        border-bottom: 0.5pt solid #999;
        border-radius: 0;
        padding: 0.4rem 0;
        margin-bottom: 0.2rem;
      }
      
      .menu-item a {
        flex-direction: row;
        gap: 1rem;
      }
      
      .menu-item:last-child {
        border-bottom: none;
      }
    }
  </style>
</Layout>
