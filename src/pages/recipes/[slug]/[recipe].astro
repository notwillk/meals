---
import Layout from '../../../layouts/Layout.astro';
import { getAllMenus, getMenu } from '../../../data/loader.ts';
import { formatDuration, formatNumeric } from '../../../utils/time.ts';
import type { Menu, Course, Dish, Component, Preparation, Step, Ingredient } from '../../../types/index.ts';

export function getStaticPaths() {
  const menus = getAllMenus();
  const paths: { params: { slug: string; recipe: string } }[] = [];
  
  menus.forEach((menu: Menu) => {
    const fullMenu = getMenu(menu.slug);
    if (!fullMenu) return;
    
    fullMenu.courses.forEach((course: Course) => {
      course.dishes.forEach((dish: Dish) => {
        if (dish.slug) {
          paths.push({
            params: { slug: menu.slug, recipe: dish.slug }
          });
        }
      });
    });
  });
  
  return paths;
}

const { slug, recipe: recipeSlug } = Astro.params;
const menu = getMenu(slug);

if (!menu) {
  return Astro.redirect('/404');
}

let dish: Dish | null = null;
menu.courses.forEach((course: Course) => {
  course.dishes.forEach((d: Dish) => {
    if (d.slug === recipeSlug) {
      dish = d;
    }
  });
});

if (!dish) {
  return Astro.redirect('/404');
}

const menuStartTime = menu.start_time ? new Date(menu.start_time).getTime() : null;

function getPreparationOffset(preparationTime: string): string | null {
  if (!menuStartTime || !preparationTime) return null;
  const prepMs = new Date(preparationTime).getTime();
  const offsetMs = prepMs - menuStartTime;
  const offsetSec = Math.round(offsetMs / 1000);
  
  let offsetStr: string;
  if (offsetSec === 0) {
    offsetStr = 'T=0';
  } else {
    const prefix = offsetSec > 0 ? 'T+' : 'T-';
    const absSec = Math.abs(offsetSec);
    
    if (absSec < 60) {
      offsetStr = `${prefix}${absSec}s`;
    } else {
      const absMin = absSec / 60;
      if (absMin < 60) {
        offsetStr = `${prefix}${formatNumeric(absMin)}m`;
      } else {
        const absHrs = absSec / 3600;
        offsetStr = `${prefix}${formatNumeric(absHrs)}h`;
      }
    }
  }
  
  const dt = new Date(preparationTime);
  const month = (dt.getMonth() + 1).toString().padStart(2, '0');
  const day = dt.getDate().toString().padStart(2, '0');
  let hours = dt.getHours();
  const minutes = dt.getMinutes().toString().padStart(2, '0');
  const ampm = hours >= 12 ? 'pm' : 'am';
  hours = hours % 12 || 12;
  
  return `${offsetStr} (${month}/${day} ${hours}:${minutes}${ampm})`;
}

function getPreparationEquipment(preparation: Preparation): string[] {
  const equipment = new Set<string>();
  if (preparation.steps) {
    preparation.steps.forEach((step: Step) => {
      if (step.equipment) {
        step.equipment.forEach((eq: string) => equipment.add(eq));
      }
    });
  }
  return Array.from(equipment);
}

function parseQty(qty: number | string | undefined): number | null {
  if (qty === undefined) return null;
  if (typeof qty === 'number') return qty;
  if (typeof qty === 'string') {
    const trimmed = qty.trim();
    if (trimmed.includes('/')) {
      const parts = trimmed.split('/');
      if (parts.length === 2) {
        const num = parseFloat(parts[0]);
        const denom = parseFloat(parts[1]);
        if (!isNaN(num) && !isNaN(denom) && denom !== 0) {
          return num / denom;
        }
      }
    }
    const parsed = parseFloat(trimmed);
    return isNaN(parsed) ? null : parsed;
  }
  return null;
}

function getStepIngredients(step: Step): Ingredient[] {
  const ingredients = step.ingredients || [];
  return [...ingredients].sort((a, b) => {
    const aVal = parseQty(a.qty);
    const bVal = parseQty(b.qty);
    if (aVal === null && bVal === null) return 0;
    if (aVal === null) return 1;
    if (bVal === null) return -1;
    return bVal - aVal;
  });
}

function formatMenuDescription(menu: Menu): string {
  const parts: string[] = [];
  if (menu.date) {
    const dt = new Date(menu.date);
    parts.push(dt.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' }));
  }
  if (menu.start_time) {
    const date = new Date(menu.start_time);
    parts.push(date.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }));
  }
  return parts.join(' · ');
}
---

<Layout title={dish.description} description={formatMenuDescription(menu)}>
  <nav class="breadcrumbs">
    <a href="/">Menus</a><span class="sep">/</span><a href={`/meals/${slug}`}>{menu.name}</a><span class="sep">/</span><span>{dish.description}</span>
  </nav>
  
  <header class="dish-header">
    <h1>{dish.description}</h1>
  </header>
  
  {dish.components && dish.components.map((component: Component) => (
    <section class="component">
      <header class="component-header">
        <h2 class="component-title">{component.description || component.id}</h2>
      </header>
      
      {component.preparations && component.preparations.map((preparation: Preparation) => (
        <article class="preparation" id={preparation.id}>
          <header class="preparation-header">
            <div class="preparation-title-row">
              <h3 class="preparation-title">{preparation.description || preparation.id}</h3>
              {(preparation.time || preparation.duration) && (
                <p class="preparation-meta mono">
                  {preparation.time && (
                    <span class="offset">{getPreparationOffset(preparation.time)}</span>
                  )}
                  {preparation.duration && (
                    <span class="duration"> &middot; {formatDuration(preparation.duration)}</span>
                  )}
                </p>
              )}
            </div>
            
            {preparation.storage && (
              <p class="preparation-storage">
                <strong>Storage:</strong> {preparation.storage}
              </p>
            )}
            
            {getPreparationEquipment(preparation).length > 0 && (
              <p class="preparation-equipment muted">
                <strong>Equipment:</strong> {getPreparationEquipment(preparation).join(', ')}
              </p>
            )}
          </header>
          
          {preparation.steps && preparation.steps.length > 0 && (
            <div class="steps">
              {preparation.steps.map((step: Step, idx: number) => (
                <div class="step">
                  <div class="step-number">{idx + 1}</div>
                  <div class="step-content">
                    {getStepIngredients(step).length > 0 && (
                      <ul class="step-ingredients">
                        {getStepIngredients(step).map((ing: Ingredient) => (
                          <li class="ingredient">
                            {ing.qty && <span class="mono">{ing.qty} </span>}
                            {ing.unit && <span>{ing.unit} </span>}
                            {(ing.qty || ing.unit) && <span class="sep">&ndash; </span>}
                            <span class="ingredient-name">{ing.name}</span>
                            {ing.preparation && <span class="ingredient-prep muted"> ({ing.preparation})</span>}
                          </li>
                        ))}
                      </ul>
                    )}
                    <p class={`step-instruction${getStepIngredients(step).length > 0 ? ' after-ingredients' : ''}`}>{step.instruction}</p>
                    {step.note && <p class="step-note muted">{step.note}</p>}
                  </div>
                </div>
              ))}
            </div>
          )}
        </article>
      ))}
    </section>
  ))}
  
  <style>
    .dish-header {
      margin-top: var(--space-md);
      margin-bottom: var(--space-xl);
    }
    
    .dish-header h1 {
      margin-bottom: var(--space-sm);
    }
    
    .component {
      margin-bottom: var(--space-xl);
    }
    
    .component-header {
      margin-bottom: var(--space-md);
      padding-bottom: var(--space-sm);
      border-bottom: 2px solid var(--color-accent);
    }
    
    .component-title {
      margin: 0;
      font-size: 1.4rem;
      font-family: var(--font-body);
      font-weight: 600;
      color: var(--color-accent);
    }
    
    .preparation {
      border: 1px solid var(--color-border);
      border-radius: 4px;
      padding: var(--space-lg);
      margin-bottom: var(--space-lg);
      break-inside: avoid;
      page-break-inside: avoid;
      background: var(--color-surface);
    }
    
    .preparation-header {
      margin-bottom: var(--space-md);
      padding-bottom: var(--space-sm);
      border-bottom: 1px solid var(--color-border);
    }
    
    .preparation-title-row {
      margin-bottom: var(--space-sm);
    }
    
    .preparation-title-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: var(--space-md);
      flex-wrap: wrap;
    }
    
    .preparation-title {
      margin: 0;
      font-size: 1.25rem;
      font-family: var(--font-body);
      font-weight: 600;
    }
    
    .preparation-meta {
      margin: 0;
      font-size: 0.9rem;
      white-space: nowrap;
      flex-shrink: 0;
    }
    
    .offset {
      color: var(--color-accent);
      font-weight: 500;
    }
    
    .preparation-storage,
    .preparation-equipment {
      margin: var(--space-xs) 0 0 0;
      font-size: 0.9rem;
    }
    
    .steps {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }
    
    .step {
      display: grid;
      grid-template-columns: 1.5rem 1fr;
      gap: var(--space-lg);
    }
    
    .step-number {
      font-family: var(--font-mono);
      font-weight: 500;
      color: var(--color-accent);
      text-align: right;
      padding-right: var(--space-sm);
      border-right: 2px solid var(--color-accent);
    }
    
    .step-content {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
    }
    
    .step-ingredients {
      margin: 0;
      padding-left: 0;
      list-style: none;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }
    
    .step-ingredients li::before {
      content: "\0020";
      display: inline-block;
      width: 1.2em;
      margin-left: -1.2em;
      color: var(--color-text-muted);
    }
    
    .step-ingredients {
      margin: 0;
      padding-left: 0;
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: var(--space-xs);
    }
    
    .step-ingredients li::before {
      content: "\0020";
      display: inline-block;
      width: 1.2em;
      margin-left: -1.2em;
      color: var(--color-text-muted);
    }
    
    .ingredient {
      font-size: 0.9rem;
      line-height: 1.3;
    }
    
    .ingredient-name {
      font-weight: 500;
    }
    
    .ingredient-prep {
      font-style: italic;
    }
    
    .step-instruction {
      margin: 0;
      line-height: 1.6;
      text-align: left;
      align-self: flex-start;
      width: 100%;
    }
    
    .step-instruction.after-ingredients {
      margin-top: var(--space-md);
    }
    
    .step-note {
      margin: 0;
      font-size: 0.9rem;
      font-style: italic;
    }
    
    @media (max-width: 600px) {
      .preparation {
        padding: var(--space-md);
      }
    }
    
    @media print {
      .breadcrumbs,
      .dish-header {
        display: none;
      }

      .preparation {
        border: 1pt solid #000;
        border-radius: 0;
        padding: 0.6rem;
        margin-bottom: 0.6rem;
        background: white !important;
        break-inside: avoid;
        page-break-inside: avoid;
      }
      
      .preparation-header {
        border-bottom: 0.5pt solid #999;
        padding-bottom: 0.4rem;
        margin-bottom: 0.4rem;
      }
      
      .preparation-title-row {
        flex-direction: row;
        flex-wrap: nowrap;
        gap: 0.5rem;
        margin-bottom: 0.3rem;
      }
      
      .preparation-title {
        font-size: 12pt;
        margin-bottom: 0;
      }
      
      .preparation-meta {
        font-size: 9pt;
        color: #333;
      }
      
      .offset {
        color: black;
        font-weight: 600;
      }
      
      .preparation-storage,
      .preparation-equipment {
        font-size: 9pt;
        color: #333;
      }
      
      .muted {
        color: #333;
      }
      
      .step {
        gap: 0.5rem;
      }
      
      .step-content {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
      }
      
      .step-ingredients {
        font-size: 9pt;
        margin: 0;
        padding-left: 0;
        list-style: none;
        gap: 0.15rem;
        align-items: flex-start;
      }
      
      .step-ingredients li::before {
        content: "\0020";
        display: inline-block;
        width: 1.2em;
        margin-left: -1.2em;
        color: #333;
      }
      
      .step-number {
        color: black;
        font-weight: 600;
        padding-right: 0.3rem;
        border-right: 0.5pt solid black;
      }
      
      .step-ingredients {
        font-size: 9pt;
        margin: 0;
        padding-left: 0;
        list-style: none;
        gap: 0.15rem;
      }
      
      .step-ingredients li::before {
        content: "\0020";
        display: inline-block;
        width: 1.2em;
        margin-left: -1.2em;
        color: #333;
      }
      
      .ingredient {
        font-size: 9pt;
      }
      
      .step-instruction {
        font-size: 10pt;
        text-align: left;
        align-self: flex-start;
        width: 100%;
      }
      
      .step-instruction.after-ingredients {
        margin-top: 0.4rem;
      }
      
      .step-note {
        font-size: 9pt;
        color: #333;
      }
    }
  </style>
</Layout>
