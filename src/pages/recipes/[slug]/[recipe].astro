---
import Layout from '../../../layouts/Layout.astro';
import { getAllMeals, getMeal } from '../../../data/loader.ts';
import { formatDuration, formatNumeric } from '../../../utils/time.ts';
import type { Meal, Course, Recipe, Phase, Step, Ingredient } from '../../../types/index.ts';

export function getStaticPaths() {
  const meals = getAllMeals();
  const paths: { params: { slug: string; recipe: string } }[] = [];
  
  meals.forEach((meal: Meal) => {
    const fullMeal = getMeal(meal.slug);
    if (!fullMeal) return;
    
    fullMeal.courses.forEach((course: Course) => {
      course.recipes.forEach((recipe: Recipe) => {
        if (recipe.slug) {
          paths.push({
            params: { slug: meal.slug, recipe: recipe.slug }
          });
        }
      });
    });
  });
  
  return paths;
}

const { slug, recipe: recipeSlug } = Astro.params;
const meal = getMeal(slug);

if (!meal) {
  return Astro.redirect('/404');
}

// Find the recipe
let recipe: Recipe | null = null;
meal.courses.forEach((course: Course) => {
  course.recipes.forEach((r: Recipe) => {
    if (r.slug === recipeSlug) {
      recipe = r;
    }
  });
});

if (!recipe) {
  return Astro.redirect('/404');
}

const mealStartTime = meal.start_time ? new Date(meal.start_time).getTime() : null;

function getPhaseOffset(phaseTime: string): string | null {
  if (!mealStartTime || !phaseTime) return null;
  const phaseMs = new Date(phaseTime).getTime();
  const offsetMs = phaseMs - mealStartTime;
  const offsetSec = Math.round(offsetMs / 1000);
  
  let offsetStr: string;
  if (offsetSec === 0) {
    offsetStr = 'T=0';
  } else {
    const prefix = offsetSec > 0 ? 'T+' : 'T-';
    const absSec = Math.abs(offsetSec);
    
    if (absSec < 60) {
      offsetStr = `${prefix}${absSec}s`;
    } else {
      const absMin = absSec / 60;
      if (absMin < 60) {
        offsetStr = `${prefix}${formatNumeric(absMin)}m`;
      } else {
        const absHrs = absSec / 3600;
        offsetStr = `${prefix}${formatNumeric(absHrs)}h`;
      }
    }
  }
  
  const dt = new Date(phaseTime);
  const month = (dt.getMonth() + 1).toString().padStart(2, '0');
  const day = dt.getDate().toString().padStart(2, '0');
  let hours = dt.getHours();
  const minutes = dt.getMinutes().toString().padStart(2, '0');
  const ampm = hours >= 12 ? 'pm' : 'am';
  hours = hours % 12 || 12;
  
  return `${offsetStr} (${month}/${day} ${hours}:${minutes}${ampm})`;
}

function getPhaseEquipment(phase: Phase): string[] {
  const equipment = new Set<string>();
  if (phase.steps) {
    phase.steps.forEach((step: Step) => {
      if (step.equipment) {
        step.equipment.forEach((eq: string) => equipment.add(eq));
      }
    });
  }
  return Array.from(equipment);
}

function parseQty(qty: number | string | undefined): number | null {
  if (qty === undefined) return null;
  if (typeof qty === 'number') return qty;
  // Handle fraction strings like "1/2", "3/4"
  if (typeof qty === 'string') {
    const trimmed = qty.trim();
    if (trimmed.includes('/')) {
      const parts = trimmed.split('/');
      if (parts.length === 2) {
        const num = parseFloat(parts[0]);
        const denom = parseFloat(parts[1]);
        if (!isNaN(num) && !isNaN(denom) && denom !== 0) {
          return num / denom;
        }
      }
    }
    const parsed = parseFloat(trimmed);
    return isNaN(parsed) ? null : parsed;
  }
  return null;
}

function getStepIngredients(step: Step): Ingredient[] {
  const ingredients = step.ingredients || [];
  return [...ingredients].sort((a, b) => {
    const aVal = parseQty(a.qty);
    const bVal = parseQty(b.qty);
    if (aVal === null && bVal === null) return 0;
    if (aVal === null) return 1;
    if (bVal === null) return -1;
    return bVal - aVal;
  });
}

---

<Layout title={recipe.description}>
  <nav class="breadcrumbs">
    <a href="/">Meals</a><span class="sep">/</span><a href={`/meals/${slug}`}>{meal.name}</a><span class="sep">/</span><span>{recipe.description}</span>
  </nav>
  
  <header class="recipe-header">
    <h1>{recipe.description}</h1>
  </header>
  
  {recipe.phases && recipe.phases.map((phase: Phase) => (
    <article class="phase" id={phase.id}>
      <header class="phase-header">
        <div class="phase-title-row">
          <h2 class="phase-title">{phase.description || phase.id}</h2>
          {(phase.time || phase.duration) && (
            <p class="phase-meta mono">
              {phase.time && (
                <span class="offset">{getPhaseOffset(phase.time)}</span>
              )}
              {phase.duration && (
                <span class="duration"> &middot; {formatDuration(phase.duration)}</span>
              )}
            </p>
          )}
        </div>
        
        {phase.storage && (
          <p class="phase-storage">
            <strong>Storage:</strong> {phase.storage}
          </p>
        )}
        
        {getPhaseEquipment(phase).length > 0 && (
          <p class="phase-equipment muted">
            <strong>Equipment:</strong> {getPhaseEquipment(phase).join(', ')}
          </p>
        )}
      </header>
      
      {phase.steps && phase.steps.length > 0 && (
        <div class="steps">
          {phase.steps.map((step: Step, idx: number) => (
            <div class="step">
              <div class="step-number">{idx + 1}</div>
              <div class="step-content">
                {getStepIngredients(step).length > 0 && (
                  <ul class="step-ingredients">
                    {getStepIngredients(step).map((ing: Ingredient) => (
                      <li class="ingredient">
                        {ing.qty && <span class="mono">{ing.qty} </span>}
                        {ing.unit && <span>{ing.unit} </span>}
                        <span class="ingredient-name">{ing.name}</span>
                        {ing.preparation && <span class="ingredient-prep muted"> ({ing.preparation})</span>}
                      </li>
                    ))}
                  </ul>
                )}
                <p class={`step-instruction${getStepIngredients(step).length > 0 ? ' after-ingredients' : ''}`}>{step.instruction}</p>
                {step.note && <p class="step-note muted">{step.note}</p>}
              </div>
            </div>
          ))}
        </div>
      )}
    </article>
  ))}
  
  <style>
    .recipe-header {
      margin-top: var(--space-md);
      margin-bottom: var(--space-xl);
    }
    
    .recipe-header h1 {
      margin-bottom: var(--space-sm);
    }
    
    .phase {
      border: 1px solid var(--color-border);
      border-radius: 4px;
      padding: var(--space-lg);
      margin-bottom: var(--space-lg);
      break-inside: avoid;
      page-break-inside: avoid;
      background: var(--color-surface);
    }
    
    .phase-header {
      margin-bottom: var(--space-md);
      padding-bottom: var(--space-sm);
      border-bottom: 1px solid var(--color-border);
    }
    
    .phase-title-row {
      margin-bottom: var(--space-sm);
    }
    
    .phase-title-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: var(--space-md);
      flex-wrap: wrap;
    }
    
    .phase-title {
      margin: 0;
      font-size: 1.25rem;
      font-family: var(--font-body);
      font-weight: 600;
    }
    
    .phase-meta {
      margin: 0;
      font-size: 0.9rem;
      white-space: nowrap;
      flex-shrink: 0;
    }
    
    .offset {
      color: var(--color-accent);
      font-weight: 500;
    }
    
    .phase-storage,
    .phase-equipment {
      margin: var(--space-xs) 0 0 0;
      font-size: 0.9rem;
    }
    
    .steps {
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }
    
    .step {
      display: grid;
      grid-template-columns: 1.5rem 1fr;
      gap: var(--space-lg);
    }
    
    .step-number {
      font-family: var(--font-mono);
      font-weight: 500;
      color: var(--color-accent);
      text-align: right;
      padding-right: var(--space-sm);
      border-right: 2px solid var(--color-accent);
    }
    
    .step-content {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
    }
    
    .step-ingredients {
      margin: 0;
      padding-left: 0;
      list-style: none;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }
    
    .step-ingredients li::before {
      content: "\0020";
      display: inline-block;
      width: 1.2em;
      margin-left: -1.2em;
      color: var(--color-text-muted);
    }
    
    .step-ingredients {
      margin: 0;
      padding-left: 0;
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: var(--space-xs);
    }
    
    .step-ingredients li::before {
      content: "\0020";
      display: inline-block;
      width: 1.2em;
      margin-left: -1.2em;
      color: var(--color-text-muted);
    }
    
    .ingredient {
      font-size: 0.9rem;
      line-height: 1.3;
    }
    
    .ingredient-name {
      font-weight: 500;
    }
    
    .ingredient-prep {
      font-style: italic;
    }
    
    .step-instruction {
      margin: 0;
      line-height: 1.6;
      text-align: left;
      align-self: flex-start;
      width: 100%;
    }
    
    .step-instruction.after-ingredients {
      margin-top: var(--space-md);
    }
    
    .step-note {
      margin: 0;
      font-size: 0.9rem;
      font-style: italic;
    }
    
    @media (max-width: 600px) {
      .phase {
        padding: var(--space-md);
      }
    }
    
    @media print {
      .breadcrumbs {
        display: none;
      }
      
      .recipe-header h1 {
        font-size: 16pt;
        margin-bottom: 0.5rem;
      }
      
      .phase {
        border: 1pt solid #000;
        border-radius: 0;
        padding: 0.6rem;
        margin-bottom: 0.6rem;
        background: white !important;
        break-inside: avoid;
        page-break-inside: avoid;
      }
      
      .phase-header {
        border-bottom: 0.5pt solid #999;
        padding-bottom: 0.4rem;
        margin-bottom: 0.4rem;
      }
      
      .phase-title-row {
        flex-direction: row;
        flex-wrap: nowrap;
        gap: 0.5rem;
        margin-bottom: 0.3rem;
      }
      
      .phase-title {
        font-size: 12pt;
        margin-bottom: 0;
      }
      
      .phase-meta {
        font-size: 9pt;
        color: #333;
      }
      
      .offset {
        color: black;
        font-weight: 600;
      }
      
      .phase-storage,
      .phase-equipment {
        font-size: 9pt;
        color: #333;
      }
      
      .muted {
        color: #333;
      }
      
      .step {
        gap: 0.5rem;
      }
      
      .step-content {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
      }
      
      .step-ingredients {
        font-size: 9pt;
        margin: 0;
        padding-left: 0;
        list-style: none;
        gap: 0.15rem;
        align-items: flex-start;
      }
      
      .step-ingredients li::before {
        content: "\0020";
        display: inline-block;
        width: 1.2em;
        margin-left: -1.2em;
        color: #333;
      }
      
      .step-number {
        color: black;
        font-weight: 600;
        padding-right: 0.3rem;
        border-right: 0.5pt solid black;
      }
      
      .step-ingredients {
        font-size: 9pt;
        margin: 0;
        padding-left: 0;
        list-style: none;
        gap: 0.15rem;
      }
      
      .step-ingredients li::before {
        content: "\0020";
        display: inline-block;
        width: 1.2em;
        margin-left: -1.2em;
        color: #333;
      }
      
      .ingredient {
        font-size: 9pt;
      }
      
      .step-instruction {
        font-size: 10pt;
        text-align: left;
        align-self: flex-start;
        width: 100%;
      }
      
      .step-instruction.after-ingredients {
        margin-top: 0.4rem;
      }
      
      .step-note {
        font-size: 9pt;
        color: #333;
      }
    }
  </style>
</Layout>
