---
import Layout from '../../../layouts/Layout.astro';
import { getAllMeals, getMeal } from '../../../data/loader.js';

export function getStaticPaths() {
  const meals = getAllMeals();
  const paths = [];
  
  meals.forEach(meal => {
    const fullMeal = getMeal(meal.slug);
    if (!fullMeal) return;
    
    fullMeal.courses.forEach(course => {
      course.recipes.forEach(recipe => {
        if (recipe.slug) {
          paths.push({
            params: { slug: meal.slug, recipe: recipe.slug }
          });
        }
      });
    });
  });
  
  console.log('Recipe paths:', paths);
  return paths;
}

const { slug, recipe: recipeSlug } = Astro.params;
const meal = getMeal(slug);

if (!meal) {
  return Astro.redirect('/404');
}

// Find the recipe
let recipe = null;
meal.courses.forEach(course => {
  course.recipes.forEach(r => {
    if (r.slug === recipeSlug) {
      recipe = r;
    }
  });
});

if (!recipe) {
  return Astro.redirect('/404');
}

const mealStartTime = meal.start_time ? new Date(meal.start_time).getTime() : null;

function formatNumeric(value) {
  const num = parseFloat(value.toFixed(2));
  return num.toString();
}

function getPhaseOffset(phaseTime) {
  if (!mealStartTime || !phaseTime) return null;
  const phaseMs = new Date(phaseTime).getTime();
  const offsetMs = phaseMs - mealStartTime;
  const offsetSec = Math.round(offsetMs / 1000);
  
  let offsetStr;
  if (offsetSec === 0) {
    offsetStr = 'T=0';
  } else {
    const prefix = offsetSec > 0 ? 'T+' : 'T-';
    const absSec = Math.abs(offsetSec);
    
    if (absSec < 60) {
      offsetStr = `${prefix}${absSec}s`;
    } else {
      const absMin = absSec / 60;
      if (absMin < 60) {
        offsetStr = `${prefix}${formatNumeric(absMin)}m`;
      } else {
        const absHrs = absSec / 3600;
        offsetStr = `${prefix}${formatNumeric(absHrs)}h`;
      }
    }
  }
  
  const dt = new Date(phaseTime);
  const month = (dt.getMonth() + 1).toString().padStart(2, '0');
  const day = dt.getDate().toString().padStart(2, '0');
  let hours = dt.getHours();
  const minutes = dt.getMinutes().toString().padStart(2, '0');
  const ampm = hours >= 12 ? 'pm' : 'am';
  hours = hours % 12 || 12;
  
  return `${offsetStr} (${month}/${day} ${hours}:${minutes}${ampm})`;
}

function formatDuration(durationStr) {
  if (!durationStr) return null;
  const match = durationStr.match(/^PT(?:(\d+)H)?(?:(\d+)M)?(?:(\d+)S)?/);
  if (!match) return durationStr;
  
  const hours = parseInt(match[1] || 0);
  const minutes = parseInt(match[2] || 0);
  const seconds = parseInt(match[3] || 0);
  
  if (hours > 0) {
    return `${hours}h ${minutes}m`;
  } else if (minutes > 0) {
    return `${minutes}m`;
  } else {
    return `${seconds}s`;
  }
}

// Get all equipment used in a phase
function getPhaseEquipment(phase) {
  const equipment = new Set();
  if (phase.steps) {
    phase.steps.forEach(step => {
      if (step.equipment) {
        step.equipment.forEach(eq => equipment.add(eq));
      }
    });
  }
  return Array.from(equipment);
}

// Get step ingredients
function getStepIngredients(step) {
  return step.ingredients || [];
}
---

<Layout title={recipe.description}>
  <nav class="breadcrumbs">
    <a href="/">Meals</a> / <a href={`/meals/${slug}`}>{meal.name}</a> / <span>{recipe.description}</span>
  </nav>
  <h1>{recipe.description}</h1>
  
  {recipe.phases && recipe.phases.map(phase => (
    <div class="phase" id={phase.id}>
      <h2>{phase.description || phase.id}</h2>
      
      {(phase.time || phase.duration) && (
        <p class="phase-meta">
          {phase.time && <span><strong>Start:</strong> {getPhaseOffset(phase.time)}</span>}
          {phase.time && phase.duration && <span> | </span>}
          {phase.duration && <span><strong>Duration:</strong> {formatDuration(phase.duration)}</span>}
        </p>
      )}
      
      {phase.follows && (
        <p><strong>Follows:</strong> {phase.follows.join(', ')}</p>
      )}
      
      {phase.storage && (
        <p><strong>Storage:</strong> {phase.storage}</p>
      )}
      
      {getPhaseEquipment(phase).length > 0 && (
        <p><strong>Equipment:</strong> {getPhaseEquipment(phase).join(', ')}</p>
      )}
      
      {phase.steps && phase.steps.length > 0 && (
        <table class="steps-table">
          <thead>
            <tr>
              <th style="width: 35%;">Ingredients</th>
              <th style="width: 65%;">Steps</th>
            </tr>
          </thead>
          <tbody>
            {phase.steps.map((step, idx) => (
              <tr>
                <td class="ingredients-cell">
                  {getStepIngredients(step).length > 0 && (
                    <ul>
                      {getStepIngredients(step).map(ing => (
                        <li>
                          {ing.qty} {ing.unit} {ing.name}
                          {ing.preparation && <span style="color: #666;"> - {ing.preparation}</span>}
                          {ing.note && <span style="color: #666;"> ({ing.note})</span>}
                          {ing.homemade && <span style="color: #666;"> (see above)</span>}
                        </li>
                      ))}
                    </ul>
                  )}
                </td>
                <td class="instruction-cell">
                  <strong>{idx + 1}.</strong> {step.instruction}
                  {step.note && <p style="color: #666; font-style: italic; margin-top: 0.5rem;">{step.note}</p>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  ))}
  
  <style>
    .phase {
      margin-bottom: 2rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid #eee;
    }

    .phase-meta {
      color: #666;
      font-size: 0.9rem;
      margin-bottom: 0.5rem;
    }
    
    .steps-table {
      margin-top: 1rem;
    }
    
    .steps-table th {
      background: #f0f0f0;
      text-align: left;
      padding-left: 0.5rem;
    }
    
    .steps-table td {
      border-bottom: 1px dashed #bbb;
      padding: 0.25rem 0
    }

    .steps-table tr:last-child td {
      border-bottom: 0;
    }

    .ingredients-cell {
      vertical-align: top;
    }
    
    .ingredients-cell ul {
      margin: 0;
      padding-left: 1.25rem;
    }
    
    .ingredients-cell li {
      margin-bottom: 0.25rem;
    }
    
    .instruction-cell {
      vertical-align: top;
    }
    
    @media (max-width: 600px) {
      .steps-table th:first-child {
        width: 40%;
      }
      .steps-table th:last-child {
        width: 60%;
      }
    }
    
    .breadcrumbs {
      margin-bottom: 1rem;
      font-size: 0.875rem;
      color: #666;
    }
    .breadcrumbs a {
      color: #0066cc;
    }
    .breadcrumbs span {
      color: #333;
    }
    
    .phase {
      border: 1px solid #ddd;
      padding: 0 1rem;
      margin-bottom: 1.5rem;
      border-radius: 20px;
      break-after: avoid;
    }
  </style>
</Layout>