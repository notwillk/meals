{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "name": { "type": "string" },
    "start_time": { "type": "string" },
    "courses": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "plating": { "type": "string" },
          "dishes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "duration": { "type": "string" },
          "hidden": { "type": "boolean" },
          "first_course": { "type": "boolean" }
        },
        "required": ["name", "dishes"]
      }
    },
    "errands": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "time": { "type": "string" },
          "duration": { "type": "string" }
        },
        "required": ["name"]
      }
    }
  },
  "required": ["name", "courses"]
}
