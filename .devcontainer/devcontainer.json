{
  "name": "dev",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker": {},
    "ghcr.io/notwillk/devcontainer-features/check-jsonschema": {},
    "ghcr.io/notwillk/checksy/checksy": {},
    "ghcr.io/notwillk/swimlane/swimlane": {},
    "ghcr.io/notwillk/devcontainer-features/github-cli": {},
    "ghcr.io/notwillk/devcontainer-features/just": {},
    "ghcr.io/notwillk/devcontainer-features/jq": {},
    "ghcr.io/notwillk/devcontainer-features/pnpm": {},
    "ghcr.io/notwillk/devcontainer-features/opencode": {},
    "ghcr.io/notwillk/devcontainer-features/prettier": {},
    "ghcr.io/notwillk/devcontainer-features/watchexec": {},
    "ghcr.io/notwillk/devcontainer-features/yamllint": {},
    "ghcr.io/rocker-org/devcontainer-features/pandoc": {}
  },
  "containerEnv": {
    "ASTRO_TELEMETRY_DISABLED": "1",
    "DEVCONTAINER": "true",
    "FIREWORKS_API_KEY": "${localEnv:FIREWORKS_API_KEY}",
    "OPENCODE_API_KEY": "${localEnv:OPENCODE_API_KEY}",
    "OPENCODE_CONFIG": "${containerWorkspaceFolder}/opencode.json",
    "OPENCODE_TELEMETRY_DISABLED": "1",
    "REPO_PATH": "${containerWorkspaceFolder}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "astro-build.astro-vscode",
        "github.vscode-github-actions",
        "skellock.just",
        "sst-dev.opencode"
      ]
    }
  },
  "remoteUser": "vscode",
  "postCreateCommand": "just doctor --fix",
  "postAttachCommand": "just doctor"
}
