{
  "chat.tools.terminal.autoApprove": {
    "checksy": true,
    "just": true
  },
  "editor.insertSpaces": true,
  "editor.tabSize": 2,
  "[just]": {
    "editor.tabSize": 4,
  },
  "json.schemaDownload.trustedDomains": {
    "https://models.dev/model-schema.json": true,
    "https://opencode.ai/config.json": true
  },
  "json.schemas": [
    {
      "fileMatch": [".swimlane.yaml"],
      "url": "./.schemas/swimlane-config.json"
    },
    {
      "fileMatch": ["*.meal.yaml"],
      "url": "./.schemas/meal.schema.json"
    },
    {
      "fileMatch": ["*.recipe.yaml"],
      "url": "./.schemas/recipe.schema.json"
    }
  ]
}
