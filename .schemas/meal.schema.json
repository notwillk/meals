{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/meal.schema.json",
  "title": "Meal",
  "type": "object",
  "required": ["name", "date", "courses"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the meal"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Date of the meal (YYYY-MM-DD)"
    },
    "service_time": {
      "type": "string",
      "description": "Service time in ISO 24-hour format (e.g., '19:00')"
    },
    "courses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description", "recipes"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the course (e.g., Amuse-Bouche, Salad, Appetizer)"
          },
          "description": {
            "type": "string",
            "description": "Description of the course"
          },
          "plating": {
            "type": "string",
            "description": "Plating instructions or vessel"
          },
          "recipes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of recipe references (paths or anchors like '&recipes/celeriac-veloute')"
          },
          "hidden": {
            "type": "boolean",
            "description": "Whether this course is hidden (e.g., Intermezzo)"
          },
          "service_offset": {
            "type": "string",
            "description": "Service offset relative to service time (e.g., 'T+10min', 'T+2hr', 'T-20min')"
          }
        }
      }
    }
  }
}